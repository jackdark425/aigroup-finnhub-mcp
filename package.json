{
  "name": "aigroup-finnhub-mcp",
  "version": "1.2.1",
  "description": "Finnhub market data MCP server for quotes, fundamentals, technical analysis, news sentiment, and crypto workflows.",
  "type": "module",
  "author": {
    "name": "AI Group",
    "email": "jackdark425@gmail.com",
    "url": "https://github.com/jackdark425"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
