# Finnhub API Configuration
FINNHUB_API_KEY=your_api_key_here
FINNHUB_BASE_URL=https://finnhub.io/api/v1

# Storage Configuration
FINNHUB_STORAGE_DIR=./finnhub-data

# Performance Settings
FINNHUB_RATE_LIMIT_RPM=60
FINNHUB_REQUEST_TIMEOUT=30
FINNHUB_MAX_RETRIES=3
FINNHUB_SAFE_TOKEN_LIMIT=75000

# Job Settings
FINNHUB_MAX_CONCURRENT_JOBS=5
FINNHUB_JOB_TIMEOUT=300

# Tool Enablement (set to false to disable specific tools)
FINNHUB_ENABLE_TECHNICAL_ANALYSIS=true
FINNHUB_ENABLE_STOCK_MARKET_DATA=true
FINNHUB_ENABLE_NEWS_SENTIMENT=true
FINNHUB_ENABLE_STOCK_FUNDAMENTALS=true
FINNHUB_ENABLE_STOCK_ESTIMATES=true
FINNHUB_ENABLE_STOCK_OWNERSHIP=true
FINNHUB_ENABLE_ALTERNATIVE_DATA=true
FINNHUB_ENABLE_SEC_FILINGS=true
FINNHUB_ENABLE_CRYPTO_DATA=true
FINNHUB_ENABLE_FOREX_DATA=true
FINNHUB_ENABLE_CALENDAR_DATA=true
FINNHUB_ENABLE_MARKET_EVENTS=true

# Logging
LOG_LEVEL=info
